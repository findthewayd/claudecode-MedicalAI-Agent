# ===== LLM 模型配置 =====
# 可选: deepseek | zhipu | spark | openai
LLM_PROVIDER=deepseek

# DeepSeek（默认推荐）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_API_BASE=https://api.deepseek.com

# 智谱 AI（切换到 LLM_PROVIDER=zhipu 时使用）
# ZHIPU_API_KEY=your-zhipu-key-here
# ZHIPU_MODEL=glm-4-plus

# 讯飞星火（切换到 LLM_PROVIDER=spark 时使用）
# SPARK_API_KEY=your-spark-key-here
# SPARK_API_SECRET=your-spark-secret-here
# SPARK_APP_ID=your-spark-app-id-here
# SPARK_MODEL=spark-lite

# OpenAI 原生（切换到 LLM_PROVIDER=openai 时使用）
# OPENAI_MODEL=gpt-4o

# ===== Neo4j Aura（可选，不配置则自动用本地 NetworkX）=====
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USERNAME=your-username
# NEO4J_PASSWORD=your-password

# ===== 限流配置 =====
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60

# ===== 日志级别 =====
LOG_LEVEL=INFO
